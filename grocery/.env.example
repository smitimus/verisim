# ============================================
# Service: verisim-grocery (dev stack)
# Self-contained: postgres + api + ui + generator.
# Copy to .env and fill in YOUR_* values.
# ============================================

CONF=YOUR_INSTALL_DIR/conf
DATA=YOUR_INSTALL_DIR/data
MEDIA=YOUR_INSTALL_DIR/media
PUID=1000
PGID=1000
TZ=America/New_York
IP=YOUR_SERVER_IP
HOMEPAGE_GROUP=Data

# DB credentials
VERISIM_POSTGRES_USER=verisim
VERISIM_POSTGRES_PASSWORD=verisim
VERISIM_GROCERY_DB=grocery

# Ports (match production)
VERISIM_POSTGRES_PORT=5499
VERISIM_API_PORT=8010
VERISIM_UI_PORT=8501
