# ============================================
# Service: verisim-gas-station (generator)
# Requires verisim-base stack to be running.
# Copy to .env and fill in YOUR_* values.
# ============================================

CONF=YOUR_INSTALL_DIR/conf
DATA=YOUR_INSTALL_DIR/data
MEDIA=YOUR_INSTALL_DIR/media
PUID=1000
PGID=1000
TZ=America/New_York
IP=YOUR_SERVER_IP
HOMEPAGE_GROUP=Data

# Shared DB credentials — must match base/.env
VERISIM_POSTGRES_USER=verisim
VERISIM_POSTGRES_PASSWORD=verisim
VERISIM_POSTGRES_DB=gas_station
